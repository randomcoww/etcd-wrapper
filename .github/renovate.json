{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "maxMajorIncrement": 0,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "ignoreTests": true,
      "groupName": "minor-update"
    },
    {
      "matchDatasources": [
        "terraform-provider",
        "terraform-module"
      ],
      "registryUrls": [
        "https://registry.opentofu.org"
      ]
    },
    {
      "matchManagers": [
        "github-actions",
        "dockerfile"
      ],
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": false
    }
  ]
}